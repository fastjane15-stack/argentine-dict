{
  "version": "2.3",

  "post_fix": {
    "tener un buen fin de semana": "Buen finde",
    "que tenga un buen fin de semana": "Buen finde",
    "le deseo un buen fin de semana": "Buen finde"
  },

  "hard_lock": {
    "早上好": "Buen día",
    "下午好": "Buenas",
    "晚上好": "Buenas",
    "周末愉快": "Buen finde",
    "谢谢": "Gracias",
    "好的": "Dale",
    "好的，没问题": "Dale, todo bien",
    "你好": "Hola"
  }

  "formal_kill": [
    "estimado",
    "le informamos",
    "le solicitamos",
    "a la brevedad",
    "por este medio",
    "cordialmente",
    "atentamente"
  ],

  "words": {
    "dinero": "guita",
    "trabajo": "laburo",
    "persona": "pibe",
    "personas": "pibes",
    "información": "info",
    "telefono": "celu",
    "teléfono": "celu",
    "autobús": "bondi",
    "empresa": "laburo",
    "empleado": "pibe"
  },

  "phrases": {
    "ha sido acreditado": "ya te entró",
    "se ha realizado": "ya está hecho",
    "puede verificar": "podés ver",
    "debe completar": "tenés que completar",
    "le pedimos que": "",
    "por favor confirme": "confirmame",
    "gracias por su paciencia": "gracias por la onda",
    "en breve nos contactaremos": "en un rato te escribo",

    "hemos recibido su pago": "ya entró la guita",
    "su depósito fue confirmado": "ya quedó acreditado",
    "ha sido completado": "ya está listo",
    "se ha unido un nuevo miembro": "se sumó uno nuevo",
    "recibirá una recompensa": "te llevás una diferencia"
  },

  "voseo_force": {
    "tienes": "tenés",
    "puedes": "podés",
    "eres": "sos",
    "quieres": "querés",
    "debes": "tenés que",
    "necesitas": "necesitás"
  },

  "chat_simplify": {
    "perfecto": "joya",
    "muy bien": "de diez",
    "de acuerdo": "dale",
    "está bien": "todo bien"
  },

  "regex_layers": {
    "strip_formal": [
      { "pattern": "estimado.*?,?", "replace": "" },
      { "pattern": "le informamos que", "replace": "" },
      { "pattern": "por favor", "replace": "" },
      { "pattern": "a la brevedad", "replace": "" },
      { "pattern": "se le solicita", "replace": "" }
    ],

    "compress": [
      { "pattern": "usted puede", "replace": "podés" },
      { "pattern": "es necesario que", "replace": "" },
      { "pattern": "para poder", "replace": "para" },
      { "pattern": "con el fin de", "replace": "para" }
    ],

    "cleanup": [
      { "pattern": "\\s{2,}", "replace": " " },
      { "pattern": "\\s+,", "replace": "," },
      { "pattern": "\\s+\\.", "replace": "." }
    ]
  },

  "strip_symbols": true
}
